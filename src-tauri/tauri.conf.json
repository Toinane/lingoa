{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lingoa",
  "version": "0.2.0",
  "identifier": "com.lingoa.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lingoa",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src ipc: https://ipc.localhost; img-src 'self' https://avatars.githubusercontent.com data: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3NzY0QTc2REUyQTI0RTUKUldUbEpDcmVka3AyUjNUZkFNNWNnUG1YdUc3bHVGL1lBbG9tRTBFTVczcUdpRGN0QlJNbFJqbGYK",
      "endpoints": [
        "https://github.com/Toinane/lingoa/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
